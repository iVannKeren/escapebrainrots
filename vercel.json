{
  "rewrites": [
    {
      "source": "/loader/:path*",
      "destination": "/public/:path*"
    }
  ],
  "headers": [
    {
      "source": "/loader/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    }
  ]
}